<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_timesheet_employee" model="res.groups">
        <field name="name">Timesheet Employee</field>
        <field name="category_id" ref="base.module_category_services_timesheets"/>
    </record>

    <record id="group_timesheet_report_manager" model="res.groups">
        <field name="name">Timesheet Report Manager</field>
        <field name="category_id" ref="base.module_category_services_timesheets"/>
        <field name="implied_ids" eval="[(4, ref('group_timesheet_employee'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
