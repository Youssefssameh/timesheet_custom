<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="timesheet_executive_report_template">
<t t-call="web.html_container">
<t t-call="web.external_layout">

    <t t-set="o" t-value="docs[0]"/>
    <t t-foreach="o._compute_report_data()" t-as="d">

    <div class="page" style="font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 10px; color: #1a1a1a; line-height: 1.45;">

        <div style="border-bottom: 2px solid #2c3e50; padding-bottom: 8px; margin-bottom: 12px;">
            <h2 style="margin:0; font-size:15px; font-weight:700; color:#2c3e50;">
                Executive Summary – <t t-esc="d['month_label']"/> Activity Report
            </h2>
            <p style="margin:4px 0 0 0; font-size:9px; color:#555;">
                <strong>Employee:</strong> <t t-esc="d['employee_name']"/>
                &#160;&#160;|&#160;&#160;
                <strong>Period:</strong> <t t-esc="d['date_from']"/> – <t t-esc="d['date_to']"/>
                &#160;&#160;|&#160;&#160;
                <strong>Total Hours:</strong> <t t-esc="d['total_hhmm']"/> hrs
            </p>
        </div>

        <h3 style="font-size:10px; font-weight:700; color:#2c3e50; margin:0 0 5px 0; text-transform:uppercase;">
            1. Time Allocation Overview
        </h3>
        <table style="width:100%; border-collapse:collapse; margin-bottom:14px; font-size:9.5px;">
            <thead>
                <tr style="background:#2c3e50; color:#fff;">
                    <th style="padding:5px 8px; text-align:left;">Category</th>
                    <th style="padding:5px 8px; text-align:center;">Hours</th>
                    <th style="padding:5px 8px; text-align:center;">Percentage</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="d['sections']" t-as="sec">
                    <tr t-attf-style="background: #{sec_index % 2 == 0 and '#f4f6f8' or '#ffffff'};">
                        <td style="padding:4px 8px;"><t t-esc="sec['name']"/></td>
                        <td style="padding:4px 8px; text-align:center;"><t t-esc="sec['hhmm']"/></td>
                        <td style="padding:4px 8px; text-align:center;"><t t-esc="sec['pct']"/>%</td>
                    </tr>
                </t>
                <tr>
                    <td style="padding:4px 8px;">Idle Time</td>
                    <td style="padding:4px 8px; text-align:center;"><t t-esc="d['idle_hhmm']"/></td>
                    <td style="padding:4px 8px; text-align:center;"><t t-esc="d['pct_idle']"/>%</td>
                </tr>
                <tr style="background:#2c3e50; color:#fff; font-weight:700;">
                    <td style="padding:5px 8px;">Total</td>
                    <td style="padding:5px 8px; text-align:center;"><t t-esc="d['total_hhmm']"/></td>
                    <td style="padding:5px 8px; text-align:center;">100.0%</td>
                </tr>
            </tbody>
        </table>

        <t t-foreach="d['sections']" t-as="sec">
            <h3 style="font-size:10px; font-weight:700; color:#2c3e50; margin:0 0 4px 0; text-transform:uppercase;">
                <t t-esc="sec_index + 2"/>. <t t-esc="sec['name']"/> (<t t-esc="sec['pct']"/>%)
            </h3>
            <div t-attf-style="margin-bottom:12px; padding-left:8px; border-left:3px solid #{sec['color']};">

                <t t-if="sec['show_projects']">
                    <t t-if="sec['project_lines']">
                        <t t-foreach="sec['project_lines']" t-as="pl">
                            <p style="margin:2px 0; font-size:9.5px;">
                                <strong><t t-esc="pl['name']"/></strong>
                                &#160;–&#160;<t t-esc="pl['hhmm']"/> hrs (<t t-esc="pl['pct']"/>%)
                            </p>
                        </t>
                    </t>
                    <t t-else="">
                        <p style="margin:2px 0; font-size:9px; color:#999;">No entries recorded.</p>
                    </t>
                </t>

                <t t-if="sec['show_types']">
                    <t t-if="sec['type_lines']">
                        <p style="margin:2px 0; font-size:9.5px; line-height:1.8;">
                            <t t-foreach="sec['type_lines']" t-as="tl">
                                <strong><t t-esc="tl['label']"/>:</strong>
                                <t t-esc="tl['hhmm']"/> (<t t-esc="tl['pct']"/>%)
                                <t t-if="not tl_last">&#160;|&#160;</t>
                            </t>
                        </p>
                    </t>
                    <t t-else="">
                        <p style="margin:2px 0; font-size:9px; color:#999;">No entries recorded.</p>
                    </t>
                </t>

            </div>
        </t>

        <h3 style="font-size:10px; font-weight:700; color:#2c3e50; margin:0 0 4px 0; text-transform:uppercase;">
            <t t-esc="len(d['sections']) + 2"/>. Idle Time (<t t-esc="d['pct_idle']"/>%)
        </h3>
        <div style="padding-left:8px; border-left:3px solid #e74c3c; margin-bottom:12px;">
            <p style="margin:2px 0; font-size:9.5px;">
                <t t-esc="d['idle_hhmm']"/> hours of downtime between tasks
            </p>
        </div>

        <div style="margin-top:16px; padding-top:6px; border-top:1px solid #ddd; font-size:8px; color:#aaa; text-align:right;">
            Confidential – For Management Review Only
        </div>

    </div>

    </t>
</t>
</t>
</template>
</odoo>
