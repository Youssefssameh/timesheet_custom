<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form_inherit_activity_type" model="ir.ui.view">
        <field name="name">project.task.form.inherit.activity.type</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='project_id']" position="after">
                <field name="show_activity_type" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="x_activity_type_id"
                    invisible="not show_activity_type"
                    required="show_activity_type"/>
            </xpath>

        </field>
    </record>
</odoo>
